<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fleetflow_trip_tree" model="ir.ui.view">
            <field name="name">fleetflow.trip.tree</field>
            <field name="model">fleetflow.trip</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <field name="cargo_weight"/>
                    <field name="state" widget="badge" 
                           decoration-info="state == 'draft'" 
                           decoration-warning="state == 'dispatched'" 
                           decoration-success="state == 'completed'" 
                           decoration-danger="state == 'cancelled'"/>
                </tree>
            </field>
        </record>

        <record id="view_fleetflow_trip_form" model="ir.ui.view">
            <field name="name">fleetflow.trip.form</field>
            <field name="model">fleetflow.trip</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_dispatch" string="Dispatch" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_complete" string="Complete" type="object" class="oe_highlight" invisible="state != 'dispatched'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state in ('completed', 'cancelled')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,dispatched,completed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="vehicle_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="driver_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="cargo_weight"/>
                            </group>
                            <group>
                                <field name="start_date" readonly="1"/>
                                <field name="end_date" readonly="1"/>
                                <field name="final_odometer" invisible="state != 'dispatched'"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_fleetflow_trip" model="ir.actions.act_window">
            <field name="name">Trips</field>
            <field name="res_model">fleetflow.trip</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
