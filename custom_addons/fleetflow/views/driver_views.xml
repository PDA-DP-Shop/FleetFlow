<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit HR Employee Form view -->
        <record id="view_employee_form_inherit_fleetflow" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.fleetflow</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Driver &amp; Safety Profile" name="driver_profile">
                        <group>
                            <group>
                                <field name="duty_status" widget="badge" 
                                       decoration-success="duty_status == 'unassigned'" 
                                       decoration-warning="duty_status == 'on_duty'" 
                                       decoration-danger="duty_status == 'suspended'"/>
                                <field name="license_expiry_date"/>
                            </group>
                            <group>
                                <field name="trip_completion_rate" widget="progressbar"/>
                                <field name="safety_score"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
