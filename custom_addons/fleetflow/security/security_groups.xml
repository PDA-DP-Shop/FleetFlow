<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- FleetFlow Category -->
        <record id="module_category_fleetflow" model="ir.module.category">
            <field name="name">FleetFlow Logistics</field>
            <field name="description">Helps you manage your fleet logistics and dispatching.</field>
            <field name="sequence">20</field>
        </record>

        <!-- Roles -->
        <record id="group_fleetflow_dispatcher" model="res.groups">
            <field name="name">Dispatcher</field>
            <field name="category_id" ref="module_category_fleetflow"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_fleetflow_safety_officer" model="res.groups">
            <field name="name">Safety Officer</field>
            <field name="category_id" ref="module_category_fleetflow"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_fleetflow_financial_analyst" model="res.groups">
            <field name="name">Financial Analyst</field>
            <field name="category_id" ref="module_category_fleetflow"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_fleetflow_manager" model="res.groups">
            <field name="name">Fleet Manager</field>
            <field name="category_id" ref="module_category_fleetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_fleetflow_dispatcher')), (4, ref('group_fleetflow_safety_officer')), (4, ref('group_fleetflow_financial_analyst'))]"/>
        </record>
    </data>
</odoo>
